RewriteEngine On

# Rewrite empty request (root of the folder) to public/index.php
RewriteRule ^$ public/index.php [L]

# Redirect any request containing "public/" in the URL to the version without it
RewriteCond %{THE_REQUEST} \s/public/([^\s?]*) [NC]
RewriteRule ^public/(.*)$ %1 [R=301,L,NE]

# Rewrite any request that doesn't point to an existing file/directory in root to public/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/$1 [L]
